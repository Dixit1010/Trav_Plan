# ─── Firebase ────────────────────────────────────────────────────────────────
# Get these from: https://console.firebase.google.com
# → Your project → Project Settings → General → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get this from: https://aistudio.google.com/app/apikey
VITE_GOOGLE_GEMINI_AI_API_KEY=AIzaSy...

# ─── Google Places (optional — for destination autocomplete) ─────────────────
# Get this from: https://console.cloud.google.com → APIs & Services → Places API
# VITE_GOOGLE_PLACES_API_KEY=AIzaSy...
